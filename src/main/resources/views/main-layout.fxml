<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.epf.pointage.ui.controller.MainLayoutController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
            <VBox spacing="2" styleClass="title-card">
                <Label text="SmartPoint EPF" styleClass="topbar-title"/>
                <Label text="Suivi des présences • Planification • Rapports" styleClass="topbar-subtitle"/>
            </VBox>
            <Pane HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="8" styleClass="user-panel" style="-fx-min-width: 350; -fx-pref-width: 400; -fx-padding: 18 20;">
                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-min-height: 32;">
                    <Label text="👤 Utilisateur connecté :" styleClass="user-status-label" style="-fx-min-height: 26;"/>
                    <Label fx:id="currentUserLabel" text="[Utilisateur]" styleClass="user-label" style="-fx-min-width: 150; -fx-min-height: 30;"/>
                </HBox>
                <Label fx:id="roleLabel" text="[RÔLE]" styleClass="badge-label" style="-fx-min-height: 28;"/>
            </VBox>
            <Button text="Déconnexion" onAction="#logout" styleClass="danger-outline-button"/>
        </HBox>
    </top>
    <left>
        <VBox spacing="6" styleClass="sidebar">
            <padding><Insets top="18" right="14" bottom="18" left="14"/></padding>
            <Button fx:id="dashboardButton" text="🏠  Tableau de bord" onAction="#showDashboard" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="professeursButton" text="👤  Professeurs" onAction="#showProfesseurs" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="coursButton" text="📚  Cours" onAction="#showCours" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="sallesButton" text="🏫  Salles" onAction="#showSalles" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="🗓  Planning" onAction="#showPlanning" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="absenceRetardsButton" text="⏱  Absences/Retards" onAction="#showAbsenceRetards" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="pointageButton" text="✅  Pointage" onAction="#showPointage" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="rapportsButton" text="📊  Rapports" onAction="#showRapports" maxWidth="Infinity" styleClass="nav-button"/>
            <Separator/>
            <Button fx:id="profilButton" text="🙍  Mon profil" onAction="#showProfil" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="utilisateursButton" text="⚙  Utilisateurs" onAction="#showUtilisateurs" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="auditButton" text="🛡  Audit connexions" onAction="#showAuditConnexions" maxWidth="Infinity" styleClass="nav-button"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-root"/>
    </center>
</BorderPane>
