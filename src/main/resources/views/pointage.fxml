<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.epf.pointage.ui.controller.PointageController" spacing="16" styleClass="page-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Pointage" styleClass="page-title"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Rafraîchir" onAction="#refresh" styleClass="secondary-button"/>
        <Button text="Pointer début" onAction="#pointerDebut" styleClass="primary-button"/>
        <Button text="Pointer fin" onAction="#pointerFin" styleClass="secondary-button"/>
    </HBox>
    <Label fx:id="contextLabel" styleClass="subtitle"/>
    <TableView fx:id="seancesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="180"/>
            <TableColumn fx:id="coursColumn" text="Cours" prefWidth="260"/>
            <TableColumn fx:id="dureeColumn" text="Durée (min)" prefWidth="120"/>
            <TableColumn fx:id="statutColumn" text="Statut séance" prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
