<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sn.epf.pointage.ui.controller.LoginController"
      styleClass="login-root">

    <!-- Panneau de marque -->
    <VBox styleClass="login-brand-panel" alignment="CENTER" spacing="26" HBox.hgrow="NEVER">
        <VBox styleClass="login-brand-badge" alignment="CENTER" spacing="10" maxWidth="360">
            <Label text="SmartPoint EPF" styleClass="login-logo"/>
            <Label text="Suivi des présences • Planification • Rapports" styleClass="login-header-subtitle" wrapText="true" maxWidth="340"/>
            <Label text="" styleClass="login-header-subtitle"/>
        </VBox>
        <Label text="Suivi des présences, plannings et rapports en toute simplicité."
               styleClass="login-brand-tagline" wrapText="true" maxWidth="300" alignment="CENTER" textAlignment="CENTER"/>
    </VBox>

    <!-- Formulaire de connexion -->
    <VBox styleClass="login-card" alignment="CENTER" HBox.hgrow="ALWAYS">
        <VBox spacing="16" styleClass="login-form" alignment="CENTER_LEFT">

            <Label text="Connexion" styleClass="login-title"/>
            <Label text="Entrez vos identifiants pour accéder au système"
                   styleClass="login-subtitle" wrapText="true"/>

            <VBox spacing="6">
                <Label text="Identifiant" styleClass="field-label"/>
                <TextField fx:id="loginField" promptText="Votre login"
                           styleClass="login-field" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Mot de passe" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Votre mot de passe"
                               styleClass="login-field" maxWidth="Infinity"/>
            </VBox>

            <Button text="SE CONNECTER" onAction="#onLogin"
                    styleClass="login-button" maxWidth="Infinity"/>

            <Label fx:id="feedbackLabel" styleClass="login-error" wrapText="true"/>

            <Label text="SmartPoint EPF © 2026 — Tous droits réservés"
                   styleClass="login-footer" alignment="CENTER" maxWidth="Infinity"/>
        </VBox>
    </VBox>
</HBox>
