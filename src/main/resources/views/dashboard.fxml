<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.epf.pointage.ui.controller.DashboardController" spacing="16" styleClass="page-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Dashboard" styleClass="page-title"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Rafraîchir" onAction="#refresh" styleClass="secondary-button"/>
    </HBox>
    <HBox spacing="12">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS"><Label text="Professeurs actifs" styleClass="stat-label"/><Label fx:id="professeursActifsLabel" styleClass="stat-value"/></VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS"><Label text="Séances aujourd'hui" styleClass="stat-label"/><Label fx:id="seancesJourLabel" styleClass="stat-value"/></VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS"><Label text="Séances réalisées ce mois" styleClass="stat-label"/><Label fx:id="seancesMoisLabel" styleClass="stat-value"/></VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS"><Label text="Retards ce mois" styleClass="stat-label"/><Label fx:id="retardsLabel" styleClass="stat-value"/></VBox>
    </HBox>
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <Label text="Répartition des statuts" styleClass="section-title"/>
            <PieChart fx:id="statutChart" VBox.vgrow="ALWAYS"/>
        </VBox>
        <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <Label text="Prochaines séances" styleClass="section-title"/>
            <TableView fx:id="upcomingTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="professeurColumn" text="Professeur" prefWidth="150"/>
                    <TableColumn fx:id="coursColumn" text="Cours" prefWidth="180"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="140"/>
                    <TableColumn fx:id="salleColumn" text="Salle" prefWidth="100"/>
                    <TableColumn fx:id="statutColumn" text="Statut" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
