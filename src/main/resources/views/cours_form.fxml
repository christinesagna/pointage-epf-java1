<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.epf.pointage.ui.controller.CoursFormController" spacing="16" styleClass="page-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Nouveau cours" styleClass="page-title"/>
    <GridPane hgap="10" vgap="10">
        <Label text="Code:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="codeField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Intitulé:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="intituleField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Volume horaire:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="volumeHoraireField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Niveau:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="niveauField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label text="Filière:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="filiereField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        <Label text="Semestre:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="semestreField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#cancel" styleClass="secondary-button"/>
        <Button text="Enregistrer" onAction="#save" styleClass="primary-button"/>
    </HBox>
</VBox>
