<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.epf.pointage.ui.controller.AuditConnexionsController" spacing="16" styleClass="page-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Audit des connexions" styleClass="page-title"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Recherche par login, IP" maxWidth="240"/>
        <ComboBox fx:id="actionBox" prefWidth="150"/>
        <DatePicker fx:id="debutPicker" promptText="Début"/>
        <DatePicker fx:id="finPicker" promptText="Fin"/>
        <Button text="Filtrer" onAction="#search" styleClass="secondary-button"/>
        <Button text="Rafraîchir" onAction="#refresh" styleClass="secondary-button"/>
    </HBox>
    <TableView fx:id="auditTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="loginColumn" text="Login" prefWidth="180"/>
            <TableColumn fx:id="horodatageColumn" text="Horodatage" prefWidth="200"/>
            <TableColumn fx:id="ipColumn" text="Adresse IP" prefWidth="180"/>
            <TableColumn fx:id="actionColumn" text="Action" prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
